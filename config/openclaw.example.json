{
  "agents": {
    "defaults": {
      "model": { "primary": "ollama/gpt-oss:20b" },
      "models": {
        "ollama/gpt-oss:20b": {},
        "ollama/qwen2.5:14b": {}
      },
      "sandbox": { "mode": "non-main" },
      "memorySearch": { "provider": "ollama", "model": "nomic-embed-text" }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": { "mode": "token", "token": "REPLACE_WITH_A_LONG_RANDOM_TOKEN" },
    "port": 18789,
    "bind": "loopback",
    "tailscale": { "mode": "serve" },
    "http": {
      "endpoints": {
        "chatCompletions": { "enabled": true }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "api": "ollama",
        "models": [
          {
            "id": "gpt-oss:20b",
            "name": "gpt-oss:20b",
            "reasoning": true,
            "compat": { "supportsTools": true },
            "input": ["text"],
            "contextWindow": 65536,
            "maxTokens": 8192,
            "params": { "num_ctx": 65536 }
          }
        ]
      }
    }
  },
  "channels": {
    "whatsapp": {
      "selfChatMode": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["+1XXXXXXXXXX"],
      "enabled": true
    }
  },
  "plugins": {
    "entries": {
      "code-dispatch": { "enabled": true }
    }
  }
}
